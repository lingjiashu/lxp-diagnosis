[Unit]
Description=LXP Inverter Diagnosis Web Service
After=network.target

[Service]
Type=simple
User=lingjiashu
WorkingDirectory=/home/lingjiashu/lxp-diagnosis
ExecStart=/home/lingjiashu/.hermes/hermes-agent/venv/bin/python3 -m uvicorn web.main:app --host 0.0.0.0 --port 8765
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
